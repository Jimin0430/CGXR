{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "default",
      "stream": "ext://sys.stdout"
    },
    "file_server": {
      "class": "logging.handlers.TimedRotatingFileHandler",
      "formatter": "default",
      "filename": "logs/server.log",
      "when": "midnight",
      "backupCount": 14,
      "encoding": "utf-8"
    },
    "file_access": {
      "class": "logging.handlers.TimedRotatingFileHandler",
      "formatter": "default",
      "filename": "logs/access.log",
      "when": "midnight",
      "backupCount": 14,
      "encoding": "utf-8"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["console", "file_server"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["console", "file_server"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["console", "file_access"],
      "level": "INFO",
      "propagate": false
    }
  }
}
